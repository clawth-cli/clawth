    "build": "bun build bin/clawth.ts --outdir dist --target node"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/picomatch": "^4.0.2",
    "@types/sql.js": "^1.4.10",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
