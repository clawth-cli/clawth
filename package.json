{
  "name": "clawth",
  "version": "0.1.0",
  "description": "CLI tool that lets Claude Code make authenticated API calls without ever seeing credentials",
  "module": "index.ts",
  "type": "module",
  "bin": {
    "clawth": "./bin/clawth.ts"
  },
  "scripts": {
    "dev": "bun run bin/clawth.ts",
